# GPU 伺服器 API（填入 LAN IP 或 Cloudflare Tunnel 域名）
WHISPER_API_URL=http://192.168.x.x:9000
OLLAMA_API_URL=http://192.168.x.x:11434

# Ollama 模型
OLLAMA_MODEL=qwen3.5:35b
OLLAMA_MODEL_FAST=qwen3.5:27b

# GitHub Repo（SSH 格式）
HUGO_SITE_REPO=git@github.com:ChenChiWang/supatagsschau.git

# Telegram 通知（選填，不設定則不發通知）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
