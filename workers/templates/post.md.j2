---
title: "{{ title }}"
date: {{ date_iso }}
draft: false
tags:
{%- for topic in topics %}
  - {{ topic | replace('"', "'") | tojson }}
{%- endfor %}
levels:
{%- for level in active_levels %}
  - {{ level }}
{%- endfor %}
video_url: "{{ video_url }}"
audio_url: "{{ audio_url }}"
summary: "{{ topics[:3] | join('、') }}"
---

{% raw %}{{< media-player >}}{% endraw %}

<script type="application/json" id="segments-data">
{{ segments | tojson }}
</script>

<div class="cefr-tabs">
  <button class="cefr-tab active" data-level="summary">📋 摘要</button>
  <button class="cefr-tab" data-level="transcript">📝 逐字稿</button>
{%- for level in active_levels %}
  <button class="cefr-tab" data-level="{{ level }}">{% if level == "A1" %}🟢 A1{% elif level == "A2" %}🟡 A2{% elif level == "B1" %}🔴 B1{% endif %}</button>
{%- endfor %}
</div>

<div class="cefr-content active" data-level="summary">

{% if summary_zh %}
{{ summary_zh }}
{% endif %}

{% if active_levels %}
<p class="cefr-hint">📊 本集學習內容：{%- for level in active_levels %}{% if level == "A1" %} 🟢 A1{% elif level == "A2" %} 🟡 A2{% elif level == "B1" %} 🔴 B1{% endif %}（{{ levels[level].vocabulary | length }} 單字 · {{ levels[level].grammar | length }} 文法 · {{ levels[level].patterns | length }} 句型）{%- endfor %} — 點擊上方分頁查看</p>
{% endif %}

</div>

<div class="cefr-content" data-level="transcript">

<div class="transcript-list">
{%- for seg in segments %}
<div class="transcript-row">
<span class="ts-link" data-time="{{ seg.start }}">{{ seg.start }}</span>
<div class="transcript-text">
<div class="transcript-de">{{ seg.de }}</div>
<div class="transcript-zh">{{ seg.zh }}</div>
</div>
</div>
{%- endfor %}
</div>

</div>

{# --- 用 macro 避免三個等級重複寫 --- #}
{% macro render_level(level_key, level_data, emoji, label_zh, label_de) %}
{% if level_data and (level_data.vocabulary or level_data.grammar or level_data.patterns) %}
<div class="cefr-content" data-level="{{ level_key }}">

### {{ emoji }} {{ level_key }} — {{ label_zh }} {{ label_de }}

{% if level_data.vocabulary %}
<h4>📖 單字 Wortschatz</h4>

<div class="vocab-list">
{%- for v in level_data.vocabulary %}
<div class="vocab-card">
<div class="vocab-head">
<span class="vocab-word">{{ v.word }}</span>
<span class="vocab-pos">{{ v.article or "" }}</span>
<span class="vocab-meaning">{{ v.meaning }}</span>
{% if v.time %}<span class="ts-link" data-time="{{ v.time }}">🔊 {{ v.time }}</span>{% endif %}
</div>
<div class="vocab-example">
<div class="vocab-de">{{ v.example }}</div>
<div class="vocab-ex-zh">{{ v.example_zh }}</div>
</div>
</div>
{%- endfor %}
</div>

{% endif %}
{% if level_data.grammar %}
<h4>📝 文法 Grammatik</h4>

{% for g in level_data.grammar %}
<details>
<summary><strong>{{ g.rule }}</strong>{% if g.time %} <span class="ts-link" data-time="{{ g.time }}">🔊 {{ g.time }}</span>{% endif %}</summary>

> **德文**：{{ g.german }}
>
> **中文**：{{ g.chinese }}

{{ g.explanation }}

</details>

{% endfor %}
{% endif %}
{% if level_data.patterns %}
<h4>💬 句型 Satzmuster</h4>

{% for p in level_data.patterns %}
<div class="pattern-card">
<div class="pattern-head">
<strong>{{ p.pattern }}</strong>
{% if p.time %}<span class="ts-link" data-time="{{ p.time }}">🔊 {{ p.time }}</span>{% endif %}
</div>
<div class="pattern-body">
<div class="pattern-de">🇩🇪 {{ p.example }}</div>
<div class="pattern-zh">🇹🇼 {{ p.translation }}</div>
<div class="pattern-note">💡 {{ p.note }}</div>
</div>
</div>

{% endfor %}
{% endif %}

</div>
{% endif %}
{% endmacro %}

{{ render_level("A1", levels.get("A1"), "🟢", "初學者區", "Anfänger") }}
{{ render_level("A2", levels.get("A2"), "🟡", "初級區", "Grundstufe") }}
{{ render_level("B1", levels.get("B1"), "🔴", "中級區", "Mittelstufe") }}

