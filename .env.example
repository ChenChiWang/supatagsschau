# GPU 伺服器 API（填入 LAN IP 或 Cloudflare Tunnel 域名）
WHISPER_API_URL=http://192.168.x.x:9000
OLLAMA_API_URL=http://192.168.x.x:11434

# Ollama 模型
OLLAMA_MODEL=qwen3.5:35b
OLLAMA_MODEL_FAST=qwen3.5:27b

# Hugo 網站 Git Repo（SSH 格式）
HUGO_SITE_REPO=git@github.com:youruser/tagesschau-deutsch.git
HUGO_SITE_DIR=./output/site

# SSH Deploy Key
SSH_KEY_PATH=./ssh-keys/deploy_key

# 暫存目錄
OUTPUT_DIR=./output

# Telegram 通知（選填，不設定則不發通知）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
